@charset "utf-8";

#fbdialog_container { display: block; padding: 15px 0px 20px; }

#fbdialog_thumb_container { display: block; text-align: center; }

#fbdialog_thumb_container > img { max-height: 280px; max-width: 280px; }

#fbdialog_errormessage { text-align: center; color: rgb(204, 0, 0); margin-=
top: 20px; }

.b_dark #fbdialog_errormessage { color: rgb(255, 102, 102); }

.contents { font-size: 13px; color: rgb(102, 102, 102); }

.flagIcon { float: left; width: 20px; height: 20px; }

.fbdialog .title { font-size: 16px; color: rgb(0, 0, 0); padding-top: 3px; =
}

.message { padding: 15px 0px 20px; }

.buttonLink { background: rgb(245, 245, 245); border: 1px solid rgb(221, 22=
1, 221); color: rgb(102, 102, 102); cursor: pointer; font-size: 13px; line-=
height: 15px; font-weight: bold; padding: 0px 16px; border-radius: 2px; mar=
gin-left: 10px; text-align: center; text-decoration: none; display: inline-=
block; height: 32px; zoom: 1; }

.b_dark .buttonLink { background: rgb(249, 249, 249); }

.buttonLink:hover { background-color: rgb(249, 249, 249); text-decoration: =
none; color: rgb(17, 17, 17); border: 1px solid rgb(204, 204, 204); }

.b_dark .buttonLink:hover { background-color: rgb(245, 245, 245); }

#checkbox_region { margin-top: 22px; column-count: 2; }

#checkbox_region input { position: absolute; width: 16px; height: 16px; opa=
city: 0; cursor: pointer; left: 0px; top: 0px; margin: 1px; }

#checkbox_region label { display: inline; }

#fbdialog #checkbox_region label.cb_c { display: inline-block; position: re=
lative; margin: auto; cursor: pointer; font-size: 13px; line-height: 16px; =
height: 18px; clear: both; padding-bottom: 3px; }

.b_dark #fbdialog #checkbox_region label.cb_c .cb_t { color: rgb(210, 208, =
206); }

