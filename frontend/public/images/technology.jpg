#bepfo { z-index: 10; background-color: rgb(255, 255, 255) !important; colo=
r: rgb(68, 68, 68) !important; }

#bepfo.b_hide { display: none !important; }

#bepfo.darkMode { background-color: rgb(17, 16, 15) !important; color: rgb(=
237, 235, 233) !important; }

#bepfo #bepfm { max-width: 320px; overflow: hidden; box-sizing: border-box;=
 border-radius: 4px; }

.rwspotlight { padding-right: 376px; }

@media only screen and (max-width: 1307px) {
  .rwspotlight { padding-right: 0px; }
}

.popup { transform: scale(0); transform-origin: center top; animation-name:=
 autoOpenPopup; animation-duration: 300ms; animation-delay: 200ms; animatio=
n-timing-function: linear; animation-fill-mode: forwards; }

@keyframes autoOpenPopup {=20
  0% { transform: scale(0); }
  30% { transform: scale(0.3); }
  50% { transform: scale(0.5); }
  80% { transform: scale(0.8); }
  100% { transform: scale(1); }
}
