#rewardsLoadingAnimation.small { width: 40px; height: 40px; }

#rewardsLoadingAnimation.extraSmall { width: 20px; height: 20px; }

@keyframes spin360Deg {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
